# TMDB Rankings Configuration

# Number of pages to crawl (each page ~20 movies)
TMDB_MAX_PAGES=5

# Request timeout in seconds
REQUEST_TIMEOUT=60

# CSV output path
CSV_OUTPUT=csv_data/movie_list.csv

# --- TMDB Discover API filters (for page 2+) ---

# Watch region (ISO 3166-1 alpha-2 code)
WATCH_REGION=KR

# Minimum vote count to filter out obscure results
MIN_VOTE_COUNT=300

# Sort order
SORT_BY=vote_average.desc

# Filter by original language (leave empty for all)
ORIGINAL_LANGUAGE=

# Runtime range (minutes)
RUNTIME_MIN=0
RUNTIME_MAX=400
